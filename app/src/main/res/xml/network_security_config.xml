<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Base config: cho phép cleartext traffic cho mọi domain.
         JW player từ streamc.xyz có thể load video streams từ nhiều CDN khác nhau
         (phim1280.tv, kkphimplayer*.com, v.v.) và nhiều URL có thể là HTTP. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
</network-security-config>
