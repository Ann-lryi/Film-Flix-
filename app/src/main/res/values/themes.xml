<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Netflix-style Dark Theme for Material 3
    -->
    <style name="Theme.NguoncFlix" parent="Theme.Material3.Dark">
        <!-- Remove ActionBar / AppBar -->
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>

        <!-- Transparent system bars so the gradient/status bar blend seamlessly -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Netflix dark background -->
        <item name="android:windowBackground">@color/netflix_dark</item>

        <!-- Netflix red accent -->
        <item name="colorPrimary">@color/netflix_red</item>
    </style>

    <!-- Fullscreen player — true immersive -->
    <style name="Theme.NguoncFlix.Fullscreen" parent="Theme.Material3.Dark">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
